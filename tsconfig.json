{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react",
    "types": ["node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["lib/**/*", "utils/**/*", "jobs/**/*", "scripts/**/*", "remotion/**/*"],
  "exclude": ["node_modules", "dist"],
  "ts-node": {
    "transpileOnly": true,
    "skipIgnore": true
  }
}
